version: "3.9"

services:
  ollama:
    image: ollama/ollama
    container_name: ollama
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
    deploy:
      resources:
        reservations:
          devices:
            - capabilities: [gpu]
    runtime: nvidia

  backend:
    build:
      context: .
      dockerfile: docker/Dockerfile
    container_name: backend
    ports:
      - "8000:8000"
    depends_on:
      - ollama

volumes:
  ollama_data: